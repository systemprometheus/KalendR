{
  "name": "kalendrio-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for Kalendrio scheduling and calendar workflows",
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:http": "tsx src/http-server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:http": "node dist/http-server.js",
    "smoke": "tsx scripts/smoke-test.ts",
    "smoke:http": "tsx scripts/smoke-http.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
