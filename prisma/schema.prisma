// KalendR - Calendly-style scheduling platform for inbound sales teams
// Database schema - SQLite for dev, Postgres for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  name           String
  avatarUrl      String?
  timezone       String   @default("America/New_York")
  slug           String   @unique
  bio            String?
  welcomeMessage String?
  locale         String   @default("en")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Onboarding
  onboardingComplete Boolean @default(false)

  // Organization membership
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  orgRole        String        @default("member") // owner, admin, member

  // Relations
  eventTypes          EventType[]
  bookingsAsHost      Booking[]          @relation("HostBookings")
  availabilitySchedules AvailabilitySchedule[]
  connectedCalendars  ConnectedCalendar[]
  teamMemberships     TeamMember[]
  sessions            Session[]
  passwordResets      PasswordReset[]
  routingFormResponses RoutingFormResponse[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============================================================
// ORGANIZATION & TEAMS
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Billing
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 String  @default("free") // free, standard, teams_free, teams, enterprise
  planSeats            Int     @default(1)
  planExpiresAt        DateTime?

  // Relations
  users        User[]
  teams        Team[]
  eventTypes   EventType[]
  routingForms RoutingForm[]
}

model Team {
  id             String       @id @default(cuid())
  name           String
  slug           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  members    TeamMember[]
  eventTypes EventType[]

  @@unique([organizationId, slug])
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   String @default("member") // admin, member

  // Round-robin settings
  priority Int     @default(0) // higher = higher priority
  weight   Float   @default(1.0)
  active   Boolean @default(true)

  createdAt DateTime @default(now())

  @@unique([teamId, userId])
}

// ============================================================
// CONNECTED CALENDARS
// ============================================================

model ConnectedCalendar {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String  // google, microsoft
  providerAccountId String
  email        String
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?

  // Settings
  checkForConflicts Boolean @default(true)
  addEventsTo       Boolean @default(false) // whether to create events here
  isPrimary         Boolean @default(false)
  watchChannelId    String?
  watchResourceId   String?
  watchResourceUri  String?
  watchExpiration   DateTime?
  watchToken        String?
  watchCursorUpdatedAt DateTime?
  watchLastWebhookAt   DateTime?
  watchLastMessageNumber Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider, providerAccountId])
}

// ============================================================
// EVENT TYPES
// ============================================================

model EventType {
  id               String  @id @default(cuid())
  title            String
  slug             String
  description      String?
  color            String  @default("#0069ff")
  isActive         Boolean @default(true)
  isArchived       Boolean @default(false)

  // Ownership
  userId           String?
  user             User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  teamId           String?
  team             Team?   @relation(fields: [teamId], references: [id])

  // Type: one_on_one, group, round_robin, collective
  eventTypeKind    String  @default("one_on_one")

  // Duration
  duration         Int     @default(30) // minutes
  durationOptions  String? // JSON array of alternate durations e.g. [15, 30, 60]

  // Location
  locationType     String  @default("google_meet") // google_meet, zoom, phone, in_person, custom, ask_invitee
  locationValue    String? // phone number, address, custom instructions
  locationOptions  String? // JSON array of location options for ask_invitee

  // Scheduling settings
  minNotice        Int     @default(240)  // minutes before event can be booked
  maxFutureDays    Int     @default(60)   // how far out can be booked
  slotInterval     Int?    // minutes between start times (null = use duration)
  bufferBefore     Int     @default(0)    // minutes buffer before
  bufferAfter      Int     @default(0)    // minutes buffer after
  dailyLimit       Int?    // max bookings per day
  weeklyLimit      Int?    // max bookings per week

  // Availability
  availabilityScheduleId String?
  availabilitySchedule   AvailabilitySchedule? @relation(fields: [availabilityScheduleId], references: [id])

  // Group event settings
  maxInvitees      Int     @default(1) // for group events

  // Round-robin settings
  roundRobinMode   String? // optimize_availability, equal_distribution

  // Confirmation & booking page
  confirmationMessage String?
  redirectUrl         String?
  requiresConfirmation Boolean @default(false)

  // Custom questions
  customQuestions  String? // JSON array of question objects

  // Branding
  brandingColor    String?
  hideBranding     Boolean @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  bookings         Booking[]
  eventTypeHosts   EventTypeHost[]

  @@unique([userId, slug])
}

model EventTypeHost {
  id          String    @id @default(cuid())
  eventTypeId String
  eventType   EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  userId      String
  isRequired  Boolean   @default(false) // true = collective (must attend), false = round-robin pool
  priority    Int       @default(0)

  @@unique([eventTypeId, userId])
}

// ============================================================
// AVAILABILITY
// ============================================================

model AvailabilitySchedule {
  id       String @id @default(cuid())
  name     String @default("Working Hours")
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  timezone String @default("America/New_York")
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  rules      AvailabilityRule[]
  overrides  AvailabilityOverride[]
  eventTypes EventType[]
}

model AvailabilityRule {
  id         String               @id @default(cuid())
  scheduleId String
  schedule   AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  dayOfWeek  Int // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime  String // "09:00" format
  endTime    String // "17:00" format
  isEnabled  Boolean @default(true)

  @@unique([scheduleId, dayOfWeek, startTime])
}

model AvailabilityOverride {
  id         String               @id @default(cuid())
  scheduleId String
  schedule   AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  date       String // "2024-03-15" format
  startTime  String? // null means unavailable
  endTime    String?
  isUnavailable Boolean @default(false)
}

// ============================================================
// BOOKINGS
// ============================================================

model Booking {
  id          String   @id @default(cuid())
  uid         String   @unique @default(cuid()) // public-facing unique ID

  eventTypeId String
  eventType   EventType @relation(fields: [eventTypeId], references: [id])

  // Host
  hostId      String
  host        User     @relation("HostBookings", fields: [hostId], references: [id])

  // Timing
  startTime   DateTime
  endTime     DateTime
  timezone    String // invitee's timezone

  // Status
  status      String   @default("confirmed") // confirmed, cancelled, rescheduled, pending, no_show

  // Invitee info
  inviteeName  String
  inviteeEmail String
  inviteePhone String?
  inviteeCompany String?
  inviteeJobTitle String?
  inviteeNotes String?

  // Custom question responses
  customResponses String? // JSON

  // Location
  locationType  String?
  locationValue String?
  meetingUrl    String?

  // Cancellation/reschedule
  cancelReason    String?
  cancelledAt     DateTime?
  rescheduledTo   String? // new booking ID
  rescheduledFrom String? // original booking ID

  // Tokens for invitee actions
  cancelToken     String  @unique @default(cuid())
  rescheduleToken String  @unique @default(cuid())

  // Calendar event
  calendarEventId String?

  // Metadata
  source       String  @default("booking_page") // booking_page, embed, routing_form, api
  metadata     String? // JSON

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  notifications BookingNotification[]
}

model BookingNotification {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  type      String // confirmation, reminder, cancellation, reschedule, follow_up
  channel   String // email, sms
  recipient String // email address or phone
  sentAt    DateTime?
  status    String @default("pending") // pending, sent, failed

  scheduledFor DateTime?

  createdAt DateTime @default(now())
}

// ============================================================
// ROUTING FORMS
// ============================================================

model RoutingForm {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  description    String?
  isActive       Boolean      @default(true)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Form fields as JSON
  fields         String // JSON array of field definitions

  // Routing rules as JSON
  routes         String // JSON array of routing rules

  // Fallback behavior
  fallbackType   String  @default("message") // message, event_type, external_url
  fallbackValue  String  @default("Thank you for your interest. We'll be in touch soon.")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  responses      RoutingFormResponse[]
}

model RoutingFormResponse {
  id            String      @id @default(cuid())
  routingFormId String
  routingForm   RoutingForm @relation(fields: [routingFormId], references: [id], onDelete: Cascade)

  // Response data
  responses     String // JSON

  // Routing result
  routedTo      String? // event type ID or URL
  routedUserId  String?
  routedUser    User?   @relation(fields: [routedUserId], references: [id])

  createdAt     DateTime @default(now())
}

// ============================================================
// WORKFLOWS / NOTIFICATION TEMPLATES
// ============================================================

model WorkflowTemplate {
  id          String @id @default(cuid())
  name        String
  trigger     String // booking_created, booking_cancelled, booking_rescheduled, reminder

  // Timing for reminders
  offsetMinutes Int? // e.g., -1440 for 24h before, -30 for 30min before

  // Template
  channel     String @default("email") // email, sms
  subject     String?
  body        String

  isSystem    Boolean @default(false) // system templates can't be deleted
  isActive    Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
